{
  "name": "help-scout-mcp-server",
  "version": "1.9.0",
  "mcpName": "io.github.drewburchfield/help-scout-mcp",
  "description": "Read-only MCP server for Help Scout conversations, customers, organizations, reports, metadata, and Docs",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "help-scout-mcp-server": "dist/cli.js"
  },
  "files": [
    "dist/",
    "mcp.json",
    "README.md",
    "LICENSE",
    "claude-desktop-config.json"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "node --loader ts-node/esm src/cli.ts",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "security": "npm run security:changed",
    "security:changed": "semgrep --config .semgrep.yml --baseline-commit origin/main .",
    "security:full": "semgrep --config .semgrep.yml .",
    "security:ci": "semgrep ci",
    "test": "jest",
    "test:contract": "TS_NODE_TRANSPILE_ONLY=true node --loader ts-node/esm tests/api-contract.ts",
    "eval:load": "npm run build && node evals/load-check.mjs",
    "eval:tail": "npm run build && node evals/tail-walk.mjs",
    "test:mcp": "npm run dogfood:mcp",
    "dogfood:seed": "TS_NODE_TRANSPILE_ONLY=true node --loader ts-node/esm tests/seed-test-data.ts && TS_NODE_TRANSPILE_ONLY=true node --loader ts-node/esm tests/seed-org-customers.ts && TS_NODE_TRANSPILE_ONLY=true node --loader ts-node/esm tests/seed-integration-data.ts && npm run dogfood:seed:docs",
    "dogfood:seed:docs": "TS_NODE_TRANSPILE_ONLY=true node --loader ts-node/esm tests/seed-docs-data.ts",
    "dogfood:mcp": "npm run build && HELPSCOUT_EXPOSE_ALL_TOOLS=true TS_NODE_TRANSPILE_ONLY=true node --loader ts-node/esm tests/mcp-client-dogfood.ts",
    "dogfood:workflows": "npm run build && TS_NODE_TRANSPILE_ONLY=true node --loader ts-node/esm tests/integration-workflows.ts",
    "dogfood:full": "npm run dogfood:mcp && npm run dogfood:workflows",
    "dogfood:audit": "TS_NODE_TRANSPILE_ONLY=true node --loader ts-node/esm tests/audit-dogfood-account.ts",
    "test:forensic": "node --loader ts-node/esm tests/test-all-tools-edge-cases.ts",
    "test:docker": "node tests/test-docker.cjs",
    "test:docker:ci": "node tests/test-docker-ci.cjs",
    "clean": "rimraf dist",
    "version:patch": "node scripts/bump-version.cjs patch",
    "version:minor": "node scripts/bump-version.cjs minor",
    "version:major": "node scripts/bump-version.cjs major",
    "prepare": "node scripts/prepare.cjs",
    "prepublishOnly": "npm run clean && npm run build",
    "prepack": "npm run clean && npm run build",
    "mcpb:build": "node scripts/build-mcpb.js",
    "mcpb:pack": "npm run mcpb:build && cd helpscout-mcp-extension && npx @anthropic-ai/mcpb pack",
    "build:all": "npm run build && npm run mcpb:build",
    "sync:plugin": "node scripts/sync-plugin.cjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "modelcontextprotocol",
    "mcp-server",
    "help-scout",
    "help-scout-api",
    "helpscout",
    "help scout",
    "customer-support",
    "claude-cowork",
    "claude-code-plugin",
    "claude-desktop",
    "typescript",
    "nodejs"
  ],
  "author": {
    "name": "Drew Burchfield",
    "url": "https://github.com/drewburchfield"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drewburchfield/help-scout-mcp-server.git"
  },
  "homepage": "https://github.com/drewburchfield/help-scout-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/drewburchfield/help-scout-mcp-server/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "axios": "^1.17.0",
    "dotenv": "^16.3.1",
    "lru-cache": "^10.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "2.1.2",
    "@types/jest": "^29.5.8",
    "@types/nock": "^10.0.3",
    "@types/node": "^20.10.4",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nock": "^14.0.5",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "cross-spawn": "^7.0.6",
    "brace-expansion": "^2.1.1",
    "minimatch": "^9.0.7",
    "hono": "4.12.25",
    "@hono/node-server": "1.19.13",
    "@inquirer/editor": "4.2.16"
  }
}
